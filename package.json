{
	"name": "backend",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"dev": "nodemon",
		"build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"start": "node dist/server.js",
		"lint": "biome check src",
		"lint:fix": "biome check --write src",
		"format": "biome format --write src",
		"prepare": "husky",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.30.1",
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"express": "^5.2.1",
		"jsonwebtoken": "^9.0.3",
		"mysql2": "^3.18.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.3",
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"@types/bcryptjs": "^3.0.0",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.3.0",
		"drizzle-kit": "^0.31.9",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"nodemon": "^3.1.13",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
